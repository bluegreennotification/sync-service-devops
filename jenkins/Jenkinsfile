pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'your-repo-url'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t gcr.io/project/sync-service:${BUILD_NUMBER} .'
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker push gcr.io/project/sync-service:${BUILD_NUMBER}'
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (env.BRANCH_NAME == 'qa') {
                        sh './deploy.sh qa'
                    } else if (env.BRANCH_NAME == 'staging') {
                        sh './deploy.sh staging'
                    } else if (env.BRANCH_NAME == 'main') {
                        input "Deploy to Production?"
                        sh './deploy.sh prod'
                    }
                }
            }
        }
    }
}
